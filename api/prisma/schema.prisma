generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String @id @default(uuid())
  collegeId  String @unique
  email      String @unique
  password   String
  fullName   String
  createdAt  DateTime @default(now())
  answers    Answer[]
  leaderboardScore LeaderboardScore?
  leaderboardMatchScores LeaderboardMatchScore[]
  role       String @default("USER")
}

model LeaderboardScore {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeId           String
  email               String
  name                String
  role                String
  score               Int      @default(0)
  answersCount        Int      @default(0)
  correctAnswersCount Int      @default(0)
  snapshotAt          DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([score])
  @@index([snapshotAt])
}

model LeaderboardMatchScore {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId     String
  matchName   String
  score       Int      @default(0)
  snapshotAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}
model Match {
  id         String   @id @default(uuid())
  teamAId    String
  teamBId    String
  teamA      Team @relation("HomeTeam", fields: [teamAId], references: [id])
  teamB      Team @relation("AwayTeam", fields: [teamBId], references: [id])
  kickoffAt  DateTime
  stage      String   @default("GROUP") // GROUP, KNOCKOUT, FINAL
  round      String?
  isLocked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  questions  Question[]
  isCompleted Boolean @default(false)
}
model Question {
  id        String   @id @default(uuid())
  text      String
  type      String
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id],onDelete: Cascade)
  template  String
  options   Option[]
  answers   Answer[]
  correctTextAnswer String?

  createdAt DateTime @default(now())
}
model Option {
  id          String    @id @default(uuid())
  text        String

  questionId  String
  question    Question  @relation(fields: [questionId], references: [id],onDelete: Cascade)

  answers     Answer[]

  createdAt   DateTime @default(now())
  isCorrect   Boolean  @default(false)
}
model Answer {
  id         String   @id @default(uuid())

  userId     String
  questionId String
  optionId   String?
  textAnswer String?
  selectedOptions Json?
  user        User      @relation(fields: [userId], references: [id])
  question    Question  @relation(fields: [questionId], references: [id],onDelete: Cascade)
  option      Option?    @relation(fields: [optionId], references: [id],onDelete: Cascade)

  createdAt  DateTime @default(now())
  @@unique([userId, questionId])
}
model Team {
  id      String   @id @default(uuid())
  name    String   @unique
  players Player[]
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Player {
  id      String   @id @default(uuid())
  name    String
  teamId  String
  team    Team     @relation(fields: [teamId], references: [id])
}
